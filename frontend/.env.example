# MOIRA Frontend Environment Configuration Template
# Copy this file to .env in the frontend directory and edit the values

# Supabase configuration for client-side authentication
VITE_SUPABASE_URL="https://your-supabase-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# REST and WebSocket backend APIs (Defaults point to local development server)
VITE_API_URL="http://127.0.0.1:8001/api/v1"
VITE_WS_URL="ws://127.0.0.1:8001/ws"
