# MOIRA Environment Configuration Template
# Copy this file to .env and fill in the values

# --------------------------
# AI Model Configuration
# --------------------------
# Active AI provider — one of: nvidia | groq | openrouter | lmstudio
ACTIVE_PROVIDER="nvidia"

# NVIDIA NIM API key
NVIDIA_API_KEY=""
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_MODEL="meta/llama-3.3-70b-instruct"

# Groq
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# OpenRouter
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"

# --------------------------
# Supabase Configuration
# --------------------------
SUPABASE_URL="https://your-supabase-project-id.supabase.co"
SUPABASE_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-for-backend-RLS-bypass"
SUPABASE_JWT_SECRET="your-jwt-secret-from-api-settings"

# --------------------------
# Database & Redis (Required)
# --------------------------
# PostgreSQL connection string (Supabase Postgres)
DATABASE_URL="postgresql://postgres:password@db.your-supabase-project-id.supabase.co:5432/postgres"

# Redis connection string (provided automatically in Render deployment)
REDIS_URL="redis://localhost:6379"

# --------------------------
# Connector API Keys (Optional)
# --------------------------
# Jira Configuration
JIRA_BASE_URL=""
JIRA_EMAIL=""
JIRA_API_TOKEN=""
JIRA_DEFAULT_PROJECT="SCRUM"

# GitHub Configuration
GITHUB_TOKEN=""
GITHUB_DEFAULT_REPO_OWNER=""

# Slack Configuration
SLACK_BOT_TOKEN=""
SLACK_DEFAULT_CHANNEL="#general"

# Google Sheets Connector
GOOGLE_SERVICE_ACCOUNT_JSON=""
GOOGLE_SERVICE_ACCOUNT_B64=""
GOOGLE_AUDIT_SPREADSHEET_ID=""

# Weather API Key
OPENWEATHERMAP_API_KEY=""
OPENWEATHER_API_KEY=""

# Gmail API Key
GMAIL_API_KEY=""

# --------------------------
# Application Configuration
# --------------------------
APP_HOST="0.0.0.0"
APP_PORT="8001"
DEBUG="false"

# Fallback / Recovery Settings
MAX_RECOVERY_ATTEMPTS="3"
MAX_RETRY_ATTEMPTS="3"
RETRY_BACKOFF_BASE="2"
